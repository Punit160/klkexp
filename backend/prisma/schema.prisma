// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
  id             Int      @id @default(autoincrement())
  company_id       String
  user_id        String   @unique
  username       String
  email          String   @unique
  password       String
  reporting_head String
  doj            DateTime
  dol            DateTime?
  ctc            Float?
  phone_no       String?
  designation    String?
  dob            DateTime?
  gender         String?
  qualification  String?
  user_img       String?
  pfesi          Boolean  @default(false)
  status         Boolean  @default(true)
  created_by     String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("User")
}


model Project {
  id          Int      @id @default(autoincrement())
  company_id       String
  project_id  String   @unique
  name        String
  description String?
  start_date  DateTime
  end_date    DateTime?
  financial_year        String
  funder_name        String
  manager_id  String
  contact_person        String
  contact_person_number        String
  mou       String?
  status         Boolean  @default(true)
  created_by     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

   @@map("Project")
}

model Intervention {
  id          Int      @id @default(autoincrement())
  company_id       String
  name        String
  status         Boolean  @default(true)
  created_by     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("Intervention")
}

model ExpensePayment {
  id                       Int      @id @default(autoincrement())
  company_id               String
  project_name             String
  project_state            String
  intervention             Int @default(0)
  project_district         String
  project_village          String
  amount                   Float
  approved_amount          Float?
  final_approved_amount          Float?
  amount_change_by         Int?
  requested_by             Int
  requested_date DateTime @default(now())
  financial_year String @default("")
  manager_id               Int

  approval_status          Int  @default(0) // ✅ 0
  manager_remarks          String?

  review_assign            Boolean  @default(false) // ✅ 0
  managertoreviewer String @default("")
  reviewer_id              Int?
  reviewer_remarks         String?

  reviewer_approval_status Int  @default(0) // ✅ 0
  reviewer_status          Boolean  @default(false) // ✅ 0

  paid_amount            Float     @default(0)
  payment_status         Int       @default(0)
  
  remarks                  String?
  document                 String?
  created_by               String?

  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  transactions             ExpensePaymentTransaction[]

  @@map("ExpensePayment")
}

model ExpensePaymentTransaction {
  id              Int       @id @default(autoincrement())
  expense_id      Int
  accountant_id   Int?      // ✅ from session (no relation)

  payment_amount  Float
  payment_mode    String
  payment_date    DateTime

  reference_no    String?
  remarks         String?

  created_at      DateTime  @default(now())

  // ✅ ONLY relation with Expense
  expense         ExpensePayment @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  // ✅ INDEXES
  @@index([expense_id])
  @@index([accountant_id])
}


