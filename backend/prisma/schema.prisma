// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
  id             Int      @id @default(autoincrement())
  company_id       String
  user_id        String   @unique
  username       String
  email          String   @unique
  password       String
  reporting_head String
  doj            DateTime
  dol            DateTime?
  ctc            Float?
  phone_no       String?
  designation    String?
  role_id   Int?
  role      Role?   @relation(fields: [role_id], references: [id])
  dob            DateTime?
  gender         String?
  qualification  String?
  user_img       String?
  pfesi          Boolean  @default(false)
  status         Boolean  @default(true)
  created_by     String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("User")
}


model Project {
  id          Int      @id @default(autoincrement())
  company_id       String
  project_id  String   @unique
  name        String
  description String?
  start_date  DateTime
  end_date    DateTime?
  financial_year        String
  funder_name        String
  manager_id  String
  contact_person        String
  contact_person_number        String
  mou       String?
  status         Boolean  @default(true)
  created_by     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

   @@map("Project")
}

model Intervention {
  id          Int      @id @default(autoincrement())
  company_id       String
  name        String
  status         Boolean  @default(true)
  created_by     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("Intervention")
}

model ExpensePayment {
  id                       Int      @id @default(autoincrement())
  company_id               String
  project_name             String
  project_state            String
  intervention             Int @default(0)
  project_district         String
  project_village          String
  amount                   Float @default(0)
  approved_amount          Float? @default(0)
  final_approved_amount    Float? @default(0)
  amount_change_by         Int?
  requested_by             Int
  requested_date           DateTime @default(now())
  financial_year           String @default("")
  manager_id               Int

  // ✅ Manager approval
  approval_status          Int  @default(0)
  manager_remarks          String?
  manager_approved_at      DateTime?   // ✅ NEW

  // ✅ Reviewer
  review_assign            Boolean  @default(false)
  assign_date       DateTime?
  managertoreviewer        String @default("")
  reviewer_id              Int?
  reviewer_remarks         String?

  reviewer_approval_status Int  @default(0)
  reviewer_status          Boolean  @default(false)
  reviewer_approved_at     DateTime?   // ✅ NEW

  // ✅ Payment
  paid_amount              Float     @default(0)
  payment_status           Int       @default(0)

  remarks                  String?
  document                 String?
  created_by               String?

  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  transactions             ExpensePaymentTransaction[]

  @@map("ExpensePayment")
}

model ExpensePaymentTransaction {
  id              Int       @id @default(autoincrement())
  expense_id      Int
  accountant_id   Int?      // ✅ from session (no relation)

  payment_amount  Float
  payment_mode    String
  payment_date    DateTime

  reference_no    String?
  remarks         String?

  created_at      DateTime  @default(now())

  // ✅ ONLY relation with Expense
  expense         ExpensePayment @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  // ✅ INDEXES
  @@index([expense_id])
  @@index([accountant_id])
}


model Role {
  id          Int       @id @default(autoincrement())
  company_id               String
  name        String    @unique
  description String?

  users       User[]
  permissions RolePermission[]
  created_by               String?
  created_at  DateTime  @default(now())
}

model Permission {
  id          Int       @id @default(autoincrement())
  company_id               String
  name        String              // e.g. "create_expense"
  label       String              // UI label
  module      String              // e.g. "Expense", "Accounts"

  roles       RolePermission[]
  created_by               String?
  created_at  DateTime  @default(now())

  @@unique([company_id, name])
}

model RolePermission {
  id            Int @id @default(autoincrement())

  role_id       Int
  permission_id Int

  role          Role        @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
}


model Wallet {
  id              Int             @id @default(autoincrement())
  company_id      String
  user_id         Int             @unique
  balance         Decimal         @default(0.00) @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  walletHistories WalletHistory[]
}

model Payments {
  id            Int      @id @default(autoincrement())
  company_id    String
  user_id       Int
  accountant_id Int
  project_id    Int      @default(0)
  amount        Decimal  @db.Decimal(10, 2)
  payment_mode  String
  reference_no  String
  payment_date  DateTime
  doc_file      String?
  remarks       String?
  status        Int @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WalletHistory {
  id           Int      @id @default(autoincrement())
  company_id   String
  user_id      Int
  wallet_id    Int
  type         String
  payment_mode String
  amount       Decimal  @db.Decimal(10, 2)
  balance      Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt // ✅ FIXED
  wallet       Wallet   @relation(fields: [wallet_id], references: [id])
}


model CompanyDetail {
  id           Int      @id @default(autoincrement())
  company_id   String
  user_id      Int
  name         String
  short_name   String
  gst          String?
  pan          String?
  tan          String?
  cin          String?
  email        String?
  state_code   String?
  address      String
  city         String
  state        String
  zipcode      Int
  status       Int  @default(0)
  code         String
  bank_accounts CompanyBankAccount[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt 
}

model CompanyBankAccount {
  id                Int           @id @default(autoincrement())
  company_detail_id Int
  company           CompanyDetail @relation(fields: [company_detail_id], references: [id], onDelete: Cascade)
  bank_name         String
  ac_no             String
  branch_name       String        @default("")
  ifsc_code         String        @default("")
  is_primary        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([company_detail_id])
}



model ProductDetail {
  id           Int      @id @default(autoincrement())
  company_id   String
  user_id      Int
  name         String
  desc         String
  hsn_sac      String?
  units      String?
  status      Int  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt 
}


// Accounts 

model Purchase {
  id                Int      @id @default(autoincrement())
  company_id   String
  user_id      Int

  // e-Invoice details
  invoice_type      String?
  irn               String   @unique
  ack_no            String
  ack_date          DateTime

  // Invoice details
  invoice_no        String
  invoice_date      DateTime
  eway_bill_no      String?
  delivery_note     String?
  mode_of_payment   String?
  reference_no      String?
  reference_date    DateTime?
  buyers_order_no   String?
  other_references  String?
  dispatch_doc_no   String?
  delivery_note_date DateTime?
  dispatched_through String?
  destination       String?
  bill_of_lading_no String?
  motor_vehicle_no  String?
  terms_of_delivery String?

  // Company references (master)
  seller_company_id     Int?
  consignee_company_id  Int?
  buyer_company_id      Int?

  // Seller
  seller_name       String
  seller_address    String
  seller_cin        String?
  seller_gstin      String
  seller_state      String
  seller_state_code String
  seller_email      String?

  // Consignee (Ship to)
  consignee_name    String?
  consignee_address String?
  consignee_gstin   String?
  consignee_state   String?
  consignee_state_code String?
  consignee_email   String?

  // Buyer (Bill to)
  buyer_name        String
  buyer_address     String
  buyer_gstin       String
  buyer_state       String
  buyer_state_code  String
  buyer_pan         String?
  buyer_email       String?

  // Totals
  total_quantity    Decimal  @db.Decimal(10, 2)
  taxable_value     Decimal  @db.Decimal(12, 2)
  igst_rate         Decimal  @db.Decimal(5, 2)
  igst_amount       Decimal  @db.Decimal(12, 2)
  total_tax_amount  Decimal  @db.Decimal(12, 2)
  total_amount      Decimal  @db.Decimal(12, 2)
  amount_in_words   String?
  tax_amount_in_words String?

  vendor_bank_account_id Int?

  // Bank details (snapshot from selected vendor bank account)
  bank_name         String?
  bank_account_no   String?
  bank_ifsc_branch  String?

  // Declaration & signatory
  declaration                       String?
  authorised_signatory_name         String?
  authorised_signatory_designation  String?
  issuing_signatory_name            String?
  issuing_signatory_designation     String?
  jurisdiction                      String?

  // Approval & Tally sync tracking
  approval_status   ApprovalStatus @default(PENDING)
  approval_date     DateTime?
  approval_remarks  String?
  tally_push_status TallyPushStatus @default(NOT_PUSHED)

  items             PurchaseItem[]
  gst_details       PurchaseGstDetail[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([invoice_no])
  @@index([approval_status])
  @@index([tally_push_status])
}

model PurchaseGstDetail {
  id            Int      @id @default(autoincrement())
  purchase_id   Int
  purchase      Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)

  ledger_name   String
  rate          Decimal  @db.Decimal(5, 2)
  amount        Decimal  @db.Decimal(12, 2)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PurchaseItem {
  id            Int      @id @default(autoincrement())
  purchase_id   Int
  purchase      Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)

  description   String
  hsn_sac       String
  quantity      Decimal  @db.Decimal(10, 2)
  unit          String?
  rate          Decimal  @db.Decimal(10, 2)
  per           String?
  amount        Decimal  @db.Decimal(12, 2)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TallyPushStatus {
  NOT_PUSHED
  PUSHED
  FAILED
}


model Sales {
  id                 Int      @id @default(autoincrement())

  company_id         String
  user_id            Int

  // e-Invoice Details
  invoice_type       String?
  irn                String?  @unique
  ack_no             String?
  ack_date           DateTime?

  // Invoice Details
  invoice_no         String   @unique
  invoice_date       DateTime

  eway_bill_no       String?
  delivery_note      String?
  mode_of_payment    String?
  reference_no       String?
  reference_date     DateTime?
  buyers_order_no    String?
  other_references   String?
  dispatch_doc_no    String?
  delivery_note_date DateTime?
  dispatched_through String?
  destination        String?
  bill_of_lading_no  String?
  motor_vehicle_no   String?
  terms_of_delivery  String?

  // Company references (master)
  seller_company_id     Int?
  consignee_company_id  Int?
  buyer_company_id      Int?

  // Seller (Company)
  seller_name        String
  seller_address     String
  seller_gstin       String
  seller_state       String
  seller_state_code  String
  seller_cin         String?
  seller_email       String?

  // Consignee (Ship To)
  consignee_name       String?
  consignee_address    String?
  consignee_gstin      String?
  consignee_state      String?
  consignee_state_code String?
  consignee_email      String?

  // Buyer (Bill To)
  buyer_name         String
  buyer_address      String
  buyer_gstin        String
  buyer_state        String
  buyer_state_code   String
  buyer_pan          String?
  buyer_email        String?

  // Totals
  total_quantity      Decimal @db.Decimal(10,2)
  taxable_value       Decimal @db.Decimal(12,2)

  igst_rate           Decimal @db.Decimal(5,2) @default(0)
  igst_amount         Decimal @db.Decimal(12,2) @default(0)

  cgst_rate           Decimal @db.Decimal(5,2) @default(0)
  cgst_amount         Decimal @db.Decimal(12,2) @default(0)

  sgst_rate           Decimal @db.Decimal(5,2) @default(0)
  sgst_amount         Decimal @db.Decimal(12,2) @default(0)

  total_tax_amount    Decimal @db.Decimal(12,2)
  total_amount        Decimal @db.Decimal(12,2)

  amount_in_words     String?
  tax_amount_in_words String?

  seller_bank_account_id Int?

  // Bank Details (snapshot from selected seller bank account)
  bank_name          String?
  bank_account_no    String?
  bank_ifsc_branch   String?

  // Declaration & signatory
  declaration                       String?
  authorised_signatory_name         String?
  authorised_signatory_designation  String?
  issuing_signatory_name            String?
  issuing_signatory_designation     String?
  jurisdiction                      String?

  // Approval
  approval_status    ApprovalStatus @default(PENDING)
  approval_date      DateTime?
  approval_remarks   String?

  // Tally
  tally_push_status  TallyPushStatus @default(NOT_PUSHED)

  items              SalesItem[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([company_id])
  @@index([invoice_no])
  @@index([approval_status])
  @@index([tally_push_status])
}

model SalesItem {
  id          Int    @id @default(autoincrement())

  sales_id    Int
  sales       Sales @relation(fields: [sales_id], references: [id], onDelete: Cascade)

  sl_no       Int

  description String

  hsn_sac     String

  quantity    Decimal @db.Decimal(10,2)

  unit        String?

  rate        Decimal @db.Decimal(10,2)

  per         String?

  amount      Decimal @db.Decimal(12,2)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


