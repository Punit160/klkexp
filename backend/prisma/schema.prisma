  authorised_signatory_name        String?
  authorised_signatory_designation String?

  // Approval
  approval_status    ApprovalStatus @default(PENDING)
  approval_date      DateTime?
  approval_remarks   String?

  // Tally
  tally_push_status  TallyPushStatus @default(NOT_PUSHED)

  items              DeliveryChallanItem[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([company_id])
  @@index([challan_no])
  @@index([approval_status])
  @@index([tally_push_status])
}

model DeliveryChallanItem {
  id                  Int    @id @default(autoincrement())

  delivery_challan_id Int
  deliveryChallan     DeliveryChallan @relation(fields: [delivery_challan_id], references: [id], onDelete: Cascade)

  sl_no               Int

  description         String

  hsn_sac             String?

  quantity            Decimal @db.Decimal(10,2)

  unit                String?

  rate                Decimal @db.Decimal(10,2)

  per                 String?

  amount              Decimal @db.Decimal(12,2)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}


model JournalVoucher {
  id                 Int      @id @default(autoincrement())

  company_id         String
  user_id            Int

  // Voucher Details
  voucher_no         String?   @unique
  voucher_date       DateTime
  voucher_type       String    @default("Journal Voucher")

  // From Company (payer / booking entity)
  from_company_id    Int?
  company_name       String
  company_address    String
  company_state      String
  company_state_code String
  company_cin        String?
  company_email      String?

  // Pay To — company or employee
  payee_type         String   @default("COMPANY")
  payee_company_id   Int?
  payee_employee_id  Int?
  payee_name         String?
  payee_address      String?
  payee_state        String?
  payee_state_code   String?
  payee_gstin        String?
  payee_email        String?
  payee_designation  String?

  // Voucher Info
  narration          String?
  on_account_of      String?

  // Totals
  total_debit        Decimal   @db.Decimal(12,2)
  total_credit       Decimal   @db.Decimal(12,2)

  // Signatory
  authorised_signatory_name        String?
  authorised_signatory_designation String?

  // Approval
  approval_status    ApprovalStatus @default(PENDING)
  approval_date      DateTime?
  approval_remarks   String?

  // Tally
  tally_push_status  TallyPushStatus @default(NOT_PUSHED)

  entries            JournalVoucherEntry[]
  paymentVouchers    PaymentVoucher[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([company_id])
  @@index([voucher_no])
  @@index([approval_status])
  @@index([tally_push_status])
}

model JournalVoucherEntry {
  id                 Int      @id @default(autoincrement())

  journal_voucher_id Int
  journalVoucher     JournalVoucher @relation(fields: [journal_voucher_id], references: [id], onDelete: Cascade)

  sl_no              Int

  particulars        String

  // Debit / Credit amounts
  debit_amount       Decimal? @db.Decimal(12,2)
  credit_amount      Decimal? @db.Decimal(12,2)

  // Account Type (Dr / Cr)
  entry_type         String   // "Dr" or "Cr"

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PaymentVoucher {
  id                   Int      @id @default(autoincrement())

  company_id           String
  user_id              Int

  voucher_no           String   @unique
  voucher_date         DateTime

  payment_type         String   @default("GENERAL")
  payment_mode         String   @default("BANK")

  narration            String?
  on_account_of        String?

  from_company_id      Int?
  from_company_name    String?
  from_company_address String?
  from_company_gstin   String?

  payee_type           String   @default("COMPANY")
  payee_employee_id    Int?

  party_company_id     Int?
  party_name           String?
  party_gstin          String?
  party_address        String?

  journal_voucher_id   Int?
  journalVoucher       JournalVoucher? @relation(fields: [journal_voucher_id], references: [id], onDelete: SetNull)

  linked_document_type String?
  linked_document_id   Int?
  linked_document_no   String?
  linked_document_amount Decimal? @db.Decimal(12, 2)

  bank_account_id      Int?
  bank_name            String?
  bank_account_no      String?
  bank_ifsc            String?
  reference_no         String?
  cheque_no            String?
  cheque_date          DateTime?

  total_debit          Decimal  @db.Decimal(12, 2)
  total_credit         Decimal  @db.Decimal(12, 2)
  total_amount         Decimal  @db.Decimal(12, 2)

  authorised_signatory_name        String?
  authorised_signatory_designation String?

  approval_status      ApprovalStatus @default(PENDING)
  approval_date        DateTime?
  approval_remarks     String?

  tally_push_status    TallyPushStatus @default(NOT_PUSHED)

  entries              PaymentVoucherEntry[]
  allocations          PaymentVoucherAllocation[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([company_id])
  @@index([voucher_no])
  @@index([payment_type])
  @@index([journal_voucher_id])
  @@index([approval_status])
}

model PaymentVoucherEntry {
  id                 Int      @id @default(autoincrement())

  payment_voucher_id Int
  paymentVoucher     PaymentVoucher @relation(fields: [payment_voucher_id], references: [id], onDelete: Cascade)

  sl_no              Int
  particulars        String
  debit_amount       Decimal? @db.Decimal(12, 2)
  credit_amount      Decimal? @db.Decimal(12, 2)
  entry_type         String

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PaymentVoucherAllocation {
  id                 Int      @id @default(autoincrement())

  payment_voucher_id Int
  paymentVoucher     PaymentVoucher @relation(fields: [payment_voucher_id], references: [id], onDelete: Cascade)

  document_type      String
  document_id        Int
  document_no        String?
  document_amount    Decimal  @db.Decimal(12, 2)
  paid_amount        Decimal  @db.Decimal(12, 2)
  allocation_type    String   @default("PARTIAL")
  remarks            String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([document_type, document_id])
}

model DocumentAttachment {
  id            Int      @id @default(autoincrement())
  company_id    String
  user_id       Int
  document_type String
  document_id   Int
  file_name     String
  original_name String
  mime_type     String?
  file_size     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([company_id])
  @@index([document_type, document_id])
}

